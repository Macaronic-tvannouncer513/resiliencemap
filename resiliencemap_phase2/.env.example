# Database
POSTGRES_DB=resiliencemap
POSTGRES_USER=resiliencemap
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://resiliencemap:change_me_in_production@localhost:5432/resiliencemap

# App
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# NOAA NWS (no key required — public API)
NOAA_API_BASE=https://api.weather.gov

# USGS Earthquake (no key required — public API)
USGS_EARTHQUAKE_API=https://earthquake.usgs.gov/fdsnws/event/1/query

# FEMA NFHL (no key required — public API)
FEMA_NFHL_WFS=https://hazards.fema.gov/arcgis/rest/services/public/NFHL/MapServer/28/query

# Census (register free at https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=your_census_api_key_here

# Alerts (optional — for webhook notifications)
ALERT_WEBHOOK_URL=
ALERT_EMAIL=
